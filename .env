# Music for U 환경변수 설정
#
# 이 파일을 복사해서 ".env" 파일을 만들고,
# 실제 값을 넣어주세요.
#
# 명령어: cp .env.example .env

# =====================================================
# Google Apps Script Web App URL
# 앱스 스크립트를 배포하면 나오는 URL이에요.
# 예: https://script.google.com/macros/s/AKfycb.../exec
# =====================================================
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzwauBSWeBEh8X5vsJEYp1DdDWPdLyMNsIwC48PTiwcqE6K2us9CJ9mJMcn0x7IfAaI/exec

# =====================================================
# 배포된 웹사이트 주소
# Vercel로 배포하면 나오는 URL이에요.
# 로컬에서 테스트할 때는 http://localhost:5173 으로 설정해요.
# =====================================================
VITE_SITE_BASE_URL=http://localhost:5173
